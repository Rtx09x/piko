{
  "manifest_version": 3,
  "name": "Piko",
  "version": "0.3.0",
  "description": "A tiny AI focus companion that gives gentle browser nudges around your current goal.",
  "icons": {
    "16": "icons/piko-16.png",
    "32": "icons/piko-32.png",
    "48": "icons/piko-48.png",
    "128": "icons/piko-128.png"
  },
  "permissions": ["alarms", "scripting", "storage", "tabs"],
  "optional_permissions": ["history"],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Piko",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/piko-16.png",
      "32": "icons/piko-32.png",
      "48": "icons/piko-48.png",
      "128": "icons/piko-128.png"
    }
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
